{
  "name": "challenge-feedback",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/features/challenge-feedback/src",
  "prefix": "a11y",
  "projectType": "library",
  "tags": ["scope:features"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "defaultConfiguration": "production",
      "options": {
        "project": "libs/features/challenge-feedback/ng-package.json",
        "tsConfig": "libs/features/challenge-feedback/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/features/challenge-feedback/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "watch": false
      }
    }
  }
}
